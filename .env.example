# Safe browser configuration. The publishable key is intentionally client-visible;
# authorization is enforced by Supabase Auth, RPC checks, and Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# E2E-only values. Keep these out of Vercel unless running a dedicated test job.
E2E_BASE_URL=http://127.0.0.1:3000
E2E_SUPABASE_URL=
E2E_SUPABASE_PUBLISHABLE_KEY=
